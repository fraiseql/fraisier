# Generated by fraisier scaffold — do not edit manually
# Sudoers fragment for deployment users
# Install to /etc/sudoers.d/{{ project_name }}

{% set _admin_strategies = ['rebuild', 'restore_migrate'] %}
{% set _pg_wrapper_path = '/usr/local/libexec/fraisier/pgadmin-' ~ project_name %}
{% set _systemctl_wrapper_path = '/usr/local/libexec/fraisier/systemctl-' ~ project_name %}

# Service management via systemctl wrapper
{% for user in deploy_users %}
{{ user }} ALL=(root) NOPASSWD: {{ _systemctl_wrapper_path }} *
{% endfor %}

{% for fraise in fraises %}
{% for env_name, env_config in fraise.get('environments', {}).items() %}
{% set deploy_user = env_config.get('deploy_user', scaffold.deploy_user) %}
{% set db = env_config.get('database', {}) or {} %}
{% set strategy = db.get('strategy', '') %}
{% if strategy in _admin_strategies %}
# Database admin via wrapper ({{ strategy }} strategy)
{{ deploy_user }} ALL=(postgres) NOPASSWD: {{ _pg_wrapper_path }} *
{% endif %}
{% set install = env_config.get('install', {}) or {} %}
{% set install_user = install.get('user') %}
{% set install_cmd = install.get('command', []) %}
{% if install_user and install_cmd %}
# Dependency install as app user
{{ deploy_user }} ALL=({{ install_user }}) NOPASSWD: {{ install_cmd | join(' ') }}
{% endif %}
{% endfor %}
{% endfor %}
