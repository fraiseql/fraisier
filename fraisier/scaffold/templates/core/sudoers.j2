# Generated by fraisier scaffold — do not edit manually
# Sudoers fragment for deployment users
# Install to /etc/sudoers.d/{{ project_name }}

{% set _admin_strategies = ['rebuild', 'restore_migrate'] %}
{% set _wrapper_path = '/usr/local/libexec/fraisier/pgadmin-' ~ project_name %}

{% for fraise in fraises %}
{% for env_name, env_config in fraise.get('environments', {}).items() %}
{% set deploy_user = env_config.get('deploy_user', scaffold.deploy_user) %}
{% set svc = project_name ~ '_' ~ fraise.name ~ '_' ~ env_name %}
{% set db = env_config.get('database', {}) or {} %}
{% set strategy = db.get('strategy', '') %}
# --- {{ svc }} ---

# Service management
{{ deploy_user }} ALL=(root) NOPASSWD: /usr/bin/systemctl stop {{ svc }}.service
{{ deploy_user }} ALL=(root) NOPASSWD: /usr/bin/systemctl start {{ svc }}.service
{{ deploy_user }} ALL=(root) NOPASSWD: /usr/bin/systemctl restart {{ svc }}.service
{{ deploy_user }} ALL=(root) NOPASSWD: /usr/bin/systemctl status {{ svc }}.service
{{ deploy_user }} ALL=(root) NOPASSWD: /usr/bin/systemctl is-active {{ svc }}.service

# Log access
{{ deploy_user }} ALL=(root) NOPASSWD: /usr/bin/journalctl -u {{ svc }}.service *

{% if strategy in _admin_strategies %}
# Database admin via wrapper ({{ strategy }} strategy)
{{ deploy_user }} ALL=(postgres) NOPASSWD: {{ _wrapper_path }} *
{% endif %}
{% set install = env_config.get('install', {}) or {} %}
{% set install_user = install.get('user') %}
{% set install_cmd = install.get('command', []) %}
{% if install_user and install_cmd %}
# Dependency install as app user
{{ deploy_user }} ALL=({{ install_user }}) NOPASSWD: {{ install_cmd | join(' ') }}
{% endif %}
{% endfor %}
{% endfor %}
# Global
{{ scaffold.deploy_user }} ALL=(root) NOPASSWD: /usr/bin/systemctl daemon-reload
