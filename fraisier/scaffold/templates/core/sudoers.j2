# Generated by fraisier scaffold — do not edit manually
# Sudoers fragment for deployment users
# Install to /etc/sudoers.d/{{ project_name }}

{% for fraise in fraises %}
{% for env_name, env_config in fraise.get('environments', {}).items() %}
{% set deploy_user = env_config.get('deploy_user', scaffold.deploy_user) %}
{{ deploy_user }} ALL=(root) NOPASSWD: /usr/bin/systemctl restart {{ fraise.name }}_{{ env_name }}.service
{{ deploy_user }} ALL=(root) NOPASSWD: /usr/bin/systemctl stop {{ fraise.name }}_{{ env_name }}.service
{{ deploy_user }} ALL=(root) NOPASSWD: /usr/bin/systemctl start {{ fraise.name }}_{{ env_name }}.service
{{ deploy_user }} ALL=(root) NOPASSWD: /usr/bin/systemctl status {{ fraise.name }}_{{ env_name }}.service
{{ deploy_user }} ALL=(root) NOPASSWD: /usr/bin/systemctl is-active {{ fraise.name }}_{{ env_name }}.service
{% endfor %}
{% endfor %}
{{ scaffold.deploy_user }} ALL=(root) NOPASSWD: /usr/bin/systemctl daemon-reload
