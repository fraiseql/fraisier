# Generated by fraisier scaffold — do not edit manually
# confiture configuration for {{ project_name }}

{% for fraise in fraises %}
{% if not fraise.get('external_db', false) %}
{{ fraise.name }}:
  database:
    host: "{{ '${PGHOST:-localhost}' }}"
    port: "{{ '${PGPORT:-5432}' }}"
    name: "{{ fraise.name }}"
    user: "{{ fraise.name }}"
    password: "{{ '${' }}{{ fraise.name | upper }}_DB_PASSWORD}"
{% if fraise.get('schema_command') %}
  schema:
    command: "{{ fraise.schema_command }}"
{% endif %}
{% if fraise.get('compile_command') %}
  compile:
    command: "{{ fraise.compile_command }}"
{% endif %}
  migrations:
    directory: "migrations/{{ fraise.name }}"
    table: "confiture_migrations"

{% endif %}
{% endfor %}
