#!/usr/bin/env bash
# Generated by fraisier scaffold — do not edit manually
# Database backup script for {{ project_name }}
set -euo pipefail

BACKUP_DIR="/var/backups/{{ project_name }}"
TIMESTAMP="$(date +%Y%m%d_%H%M%S)"
RETENTION_DAYS=30
ERRORS=0

mkdir -p "${BACKUP_DIR}"

log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*"; }

{% for fraise in fraises %}
{% if not fraise.get('external_db', false) %}
# Backup {{ fraise.name }}
log "Backing up database: {{ fraise.name }}"
DUMP_FILE="${BACKUP_DIR}/{{ fraise.name }}_${TIMESTAMP}.sql.gz"
if pg_dump -h localhost -U {{ fraise.name }} {{ fraise.name }} | gzip > "${DUMP_FILE}"; then
    log "  OK: ${DUMP_FILE} ($(du -h "${DUMP_FILE}" | cut -f1))"
else
    log "  FAILED: {{ fraise.name }}"
    ERRORS=$((ERRORS + 1))
fi

{% endif %}
{% endfor %}
# Prune old backups
log "Pruning backups older than ${RETENTION_DAYS} days"
find "${BACKUP_DIR}" -name "*.sql.gz" -mtime +${RETENTION_DAYS} -delete

if [ "${ERRORS}" -gt 0 ]; then
    log "ERROR: ${ERRORS} backup(s) failed"
    exit 1
fi

log "All backups completed successfully"
