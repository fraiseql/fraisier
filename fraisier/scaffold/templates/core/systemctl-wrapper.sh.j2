#!/usr/bin/env bash
# Generated by fraisier scaffold — do not edit manually
# systemd service wrapper for {{ project_name }}
# Validates service names and actions against project allowlist before executing.
# Install to /usr/local/libexec/fraisier/systemctl-{{ project_name }}
set -euo pipefail

ALLOWED_SERVICES=(
{% for svc in allowed_services %}
    "{{ svc }}"
{% endfor %}
)

ALLOWED_ACTIONS=(start stop restart status is-active enable disable daemon-reload show)

die() { echo "fraisier-systemctl: $1" >&2; exit 1; }

[[ $# -ge 1 ]] || die "usage: systemctl-{{ project_name }} <action> [service] [args...]"

ACTION="$1"
shift

# Validate action
action_allowed=false
for act in "${ALLOWED_ACTIONS[@]}"; do
    [[ "$act" == "$ACTION" ]] && { action_allowed=true; break; }
done
$action_allowed || die "action not allowed: $ACTION"

# daemon-reload needs no service argument
if [[ "$ACTION" == "daemon-reload" ]]; then
    exec /usr/bin/systemctl daemon-reload
fi

# All other actions require a service argument
[[ $# -ge 1 ]] || die "usage: systemctl-{{ project_name }} $ACTION <service> [args...]"
SERVICE="$1"
shift

# Validate service
service_allowed=false
for svc in "${ALLOWED_SERVICES[@]}"; do
    [[ "$svc" == "$SERVICE" ]] && { service_allowed=true; break; }
done
$service_allowed || die "service not allowed: $SERVICE (allowed: ${ALLOWED_SERVICES[*]})"

# Execute systemctl command
exec /usr/bin/systemctl "$ACTION" "$SERVICE" "$@"
