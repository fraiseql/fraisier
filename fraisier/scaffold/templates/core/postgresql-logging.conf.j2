# Generated by fraisier scaffold — do not edit manually
# PostgreSQL logging configuration — {{ env_name }}
# Install to: /etc/postgresql/<version>/conf.d/fraisier.conf
# Then: sudo systemctl reload postgresql

# Logging destination
log_destination = 'stderr'
logging_collector = on
log_directory = 'log'
log_filename = 'postgresql-%Y-%m-%d.log'
log_rotation_age = {{ scaffold.postgresql.log_rotation_age }}
log_rotation_size = {{ scaffold.postgresql.log_rotation_size }}

# Line format
log_line_prefix = {{ scaffold.postgresql.log_line_prefix }}

# What to log
log_min_duration_statement = {{ scaffold.postgresql.log_min_duration_statement or pg_defaults.get('log_min_duration_statement', '500') }}
log_statement = '{{ scaffold.postgresql.log_statement or pg_defaults.get('log_statement', 'ddl') }}'

# Error logging
log_min_error_statement = {{ scaffold.postgresql.log_min_error_statement }}
log_error_verbosity = {{ scaffold.postgresql.log_error_verbosity }}

# Connection logging
{% set conn_override = scaffold.postgresql.log_connections %}
{% if conn_override is not none %}
log_connections = {{ 'on' if conn_override else 'off' }}
{% else %}
log_connections = {{ 'on' if pg_defaults.get('log_connections', false) else 'off' }}
{% endif %}

# Lock monitoring
deadlock_timeout = {{ scaffold.postgresql.deadlock_timeout }}
log_lock_waits = {{ 'on' if scaffold.postgresql.log_lock_waits else 'off' }}
