#!/usr/bin/env bash
# Generated by fraisier scaffold — do not edit manually
# Database reset script for {{ project_name }}
# WARNING: This script DROPS and recreates databases. Development use only.
set -euo pipefail

ENVIRONMENT="${1:-}"

if [ -z "${ENVIRONMENT}" ]; then
    echo "Usage: $0 <environment>"
    echo "Example: $0 development"
    exit 1
fi

if [ "${ENVIRONMENT}" = "production" ]; then
    echo "ERROR: db_reset is not allowed in production."
    exit 1
fi

echo "WARNING: This will DROP and recreate all databases for environment '${ENVIRONMENT}'."
read -rp "Type 'yes' to confirm: " CONFIRM
if [ "${CONFIRM}" != "yes" ]; then
    echo "Aborted."
    exit 0
fi

{% for fraise in fraises %}
{% if not fraise.get('external_db', false) %}
echo "==> Resetting database: {{ fraise.name }}"
dropdb --if-exists -h localhost -U postgres {{ fraise.name }}
createdb -h localhost -U postgres -O {{ fraise.name }} {{ fraise.name }}
echo "  Database {{ fraise.name }} recreated"
{% endif %}
{% endfor %}

echo "All databases reset. Run db_deploy.sh to apply migrations."
