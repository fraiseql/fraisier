#!/usr/bin/env bash
# Generated by fraisier scaffold — do not edit manually
# PostgreSQL admin wrapper for {{ project_name }}
# Validates database names against project allowlist before executing.
# Install to /usr/local/libexec/fraisier/pgadmin-{{ project_name }}
set -euo pipefail

ALLOWED_DBS=(
{% for db in pg_allowed_databases %}
    "{{ db }}"
{% endfor %}
)

ALLOWED_COMMANDS=(psql createdb dropdb pg_dump pg_restore)

die() { echo "fraisier-pgadmin: $1" >&2; exit 1; }

[[ $# -ge 1 ]] || die "usage: pgadmin-{{ project_name }} <command> [args...]"

COMMAND="$1"
shift

# Validate command
allowed=false
for cmd in "${ALLOWED_COMMANDS[@]}"; do
    [[ "$cmd" == "$COMMAND" ]] && { allowed=true; break; }
done
$allowed || die "command not allowed: $COMMAND"

# Extract target database name from arguments
extract_db() {
    local cmd="$1"; shift
    case "$cmd" in
        createdb|dropdb|pg_dump)
            # Database name is the last positional argument.
            # Skip flags and their values to find it.
            local last_positional=""
            local skip_next=false
            for arg in "$@"; do
                if $skip_next; then skip_next=false; continue; fi
                case "$arg" in
                    # Flags that consume the next argument
                    -T|-O|-h|-p|-U|-f|-F|-j|-t|-n|-N|-d|-e|-Z) skip_next=true ;;
                    --compress=*|--file=*|--jobs=*|--schema=*) ;;
                    -*) ;;
                    *) last_positional="$arg" ;;
                esac
            done
            echo "$last_positional"
            ;;
        pg_restore)
            # Database via -d flag
            local skip_next=false
            for arg in "$@"; do
                if $skip_next; then echo "$arg"; return; fi
                case "$arg" in
                    -d) skip_next=true ;;
                esac
            done
            ;;
        psql)
            # Database via -d flag (optional — admin queries have no -d)
            local skip_next=false
            for arg in "$@"; do
                if $skip_next; then echo "$arg"; return; fi
                case "$arg" in
                    -d) skip_next=true ;;
                esac
            done
            # No -d flag: admin query (e.g., pg_database, pg_stat_activity)
            ;;
    esac
}

TARGET_DB=$(extract_db "$COMMAND" "$@")

if [[ -n "$TARGET_DB" ]]; then
    # Validate against allowlist
    db_allowed=false
    for db in "${ALLOWED_DBS[@]}"; do
        [[ "$db" == "$TARGET_DB" ]] && { db_allowed=true; break; }
    done
    $db_allowed || die "database not allowed: $TARGET_DB (allowed: ${ALLOWED_DBS[*]})"
elif [[ "$COMMAND" != "psql" ]]; then
    # Non-psql commands must always target a database
    die "no database found in arguments for $COMMAND"
fi

exec "/usr/bin/$COMMAND" "$@"
