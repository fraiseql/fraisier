[Unit]
Description={{ fraise.name }} ({{ env_name }})
After=network.target
{% if fraise.get('type') == 'api' %}
After=postgresql.service
{% endif %}

[Service]
Type=notify
User={{ service.user or scaffold.deploy_user }}
Group={{ service.group or scaffold.deploy_user }}
WorkingDirectory={{ app_path }}
{% if exec_command %}
ExecStart={{ exec_command }}
{% else %}
ExecStart={{ app_path }}/.venv/bin/uvicorn {{ fraise.name }}.main:app --host 0.0.0.0 --port {{ port }} --workers {{ worker_count }}
{% endif %}
Restart=on-failure
RestartSec=5
WatchdogSec=60

# Resource limits
MemoryMax={{ memory_max }}
{% if service.memory_high %}
MemoryHigh={{ service.memory_high }}
{% endif %}
{% if service.cpu_quota %}
CPUQuota={{ service.cpu_quota }}
{% endif %}
CPUAccounting=true

{% if service.environment_file %}
# Environment file
EnvironmentFile={{ service.environment_file }}
{% endif %}
{% if service.credentials %}
# Credentials
{% for name, path in service.credentials.items() %}
LoadCredential={{ name }}:{{ path }}
{% endfor %}
{% endif %}

# Security hardening
{% for directive, value in security_directives.items() %}
{{ directive }}={{ value }}
{% endfor %}

# Writable paths
ReadWritePaths={{ app_path }}
{% if not fraise.get('external_db', false) %}
ReadWritePaths=/var/lib/postgresql
{% endif %}

# Environment
Environment=ENVIRONMENT={{ env_name }}
{% if fraise.get('type') == 'api' %}
Environment=WORKERS={{ worker_count }}
{% endif %}
{% for key, val in service.environment.items() %}
Environment={{ key }}={{ val }}
{% endfor %}

[Install]
WantedBy=multi-user.target
