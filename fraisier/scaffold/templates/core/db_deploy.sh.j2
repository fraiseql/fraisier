#!/usr/bin/env bash
# Generated by fraisier scaffold — do not edit manually
# Database deploy script for {{ project_name }}
# Runs confiture migrations for all fraise databases.
set -euo pipefail

ENVIRONMENT="${1:-production}"
PROJECT_DIR="/opt/{{ project_name }}"
ERRORS=0

log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*"; }

log "Running database migrations (environment: ${ENVIRONMENT})"

{% for fraise in fraises %}
{% if not fraise.get('external_db', false) %}
# Migrate {{ fraise.name }}
log "Migrating: {{ fraise.name }}"
if (cd "${PROJECT_DIR}" && uv run confiture migrate --database {{ fraise.name }} --environment "${ENVIRONMENT}"); then
    log "  OK: {{ fraise.name }}"
else
    log "  FAILED: {{ fraise.name }}"
    ERRORS=$((ERRORS + 1))
fi

{% endif %}
{% endfor %}
if [ "${ERRORS}" -gt 0 ]; then
    log "ERROR: ${ERRORS} migration(s) failed"
    exit 1
fi

log "All migrations completed successfully"
