# Generated by fraisier scaffold — do not edit manually
name: Deploy {{ project_name }}

on:
  push:
    branches: [main]
    paths:
      - 'version.json'
  workflow_dispatch:
    inputs:
      force_deploy:
        description: 'Force deploy even without version change'
        required: false
        default: 'false'
        type: boolean

env:
  UV_CACHE_DIR: /tmp/.uv-cache

jobs:
  test:
    runs-on: ubuntu-latest
    strategy:
      matrix:
        python-version: {{ scaffold.github_actions.python_versions | tojson }}
    steps:
      - uses: actions/checkout@v4

      - name: Install uv
        uses: astral-sh/setup-uv@v4
        with:
          enable-cache: true

      - name: Set up Python ${{ '{{' }} matrix.python-version {{ '}}' }}
        run: uv python install ${{ '{{' }} matrix.python-version {{ '}}' }}

      - name: Install dependencies
        run: uv sync --frozen

      - name: Run tests
        run: {{ scaffold.github_actions.test_command }}

  lint:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Install uv
        uses: astral-sh/setup-uv@v4
        with:
          enable-cache: true

      - name: Set up Python
        run: uv python install {{ scaffold.github_actions.python_versions[0] }}

      - name: Install dependencies
        run: uv sync --frozen

      - name: Lint
        run: {{ scaffold.github_actions.lint_command }}

      - name: Format check
        run: {{ scaffold.github_actions.format_command }}

  deploy:
    needs: [test, lint]
    runs-on: ubuntu-latest
    if: github.ref == 'refs/heads/main'
    concurrency:
      group: deploy-production
      cancel-in-progress: false
    steps:
      - uses: actions/checkout@v4

      - name: Deploy to server
        uses: appleboy/ssh-action@v1
        with:
          host: ${{ '{{' }} secrets.DEPLOY_HOST {{ '}}' }}
          username: {{ scaffold.deploy_user }}
          key: ${{ '{{' }} secrets.DEPLOY_SSH_KEY {{ '}}' }}
          script: |
            cd /opt/{{ project_name }}
            git fetch origin main
            git reset --hard origin/main
            uv sync --frozen
{% for fraise in fraises %}
{% for env_name in fraise.get('environments', {}) %}
            sudo systemctl restart {{ fraise.name }}_{{ env_name }}.service
{% endfor %}
{% endfor %}

      - name: Verify deployment
        uses: appleboy/ssh-action@v1
        with:
          host: ${{ '{{' }} secrets.DEPLOY_HOST {{ '}}' }}
          username: {{ scaffold.deploy_user }}
          key: ${{ '{{' }} secrets.DEPLOY_SSH_KEY {{ '}}' }}
          script: |
{% for fraise in fraises %}
{% for env_name in fraise.get('environments', {}) %}
            systemctl is-active {{ fraise.name }}_{{ env_name }}.service
{% endfor %}
{% endfor %}
